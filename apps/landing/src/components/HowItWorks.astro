---
const steps = [
  {
    number: '01',
    title: 'Registro de asistentes',
    description: 'Cada residente se registra y se le asigna un control unico con su apartamento y coeficiente.',
    icon: 'user',
  },
  {
    number: '02',
    title: 'Asignar dispositivos',
    description: 'Los controles se activan automaticamente al inicio de la asamblea. Sin configuracion manual.',
    icon: 'device',
  },
  {
    number: '03',
    title: 'Abrir votacion',
    description: 'El presidente abre la votacion desde el dashboard. Los controles se iluminan indicando que pueden votar.',
    icon: 'vote',
  },
  {
    number: '04',
    title: 'Voto en tiempo real',
    description: 'Cada persona presiona SI, NO o ABSTENCION. El voto se registra en menos de 200ms via RF.',
    icon: 'clock',
  },
  {
    number: '05',
    title: 'Calculo automatico',
    description: 'El sistema calcula porcentaje, coeficientes y quorum en tiempo real. Sin errores humanos.',
    icon: 'calc',
  },
  {
    number: '06',
    title: 'Acta automatica',
    description: 'Se genera el acta en PDF con todos los votos, quorum y firmas. Lista para legalizar.',
    icon: 'doc',
  },
];
---

<section id="como-funciona" class="how-it-works">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Proceso</span>
      <h2 class="section-title">Como funciona</h2>
      <p class="section-subtitle">De la注册 al acta en 6 pasos simples</p>
    </div>

    <div class="steps-grid">
      {steps.map((step, i) => (
        <div class={`step-card reveal`} style={`transition-delay: ${i * 100}ms`}>
          <div class="step-number">{step.number}</div>
          <div class="step-icon">
            {step.icon === 'user' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            )}
            {step.icon === 'device' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="5" y="2" width="14" height="20" rx="3"/>
                <circle cx="12" cy="16" r="1"/>
                <path d="M9 6h6M9 10h6"/>
              </svg>
            )}
            {step.icon === 'vote' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12l2 2 4-4"/>
                <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
              </svg>
            )}
            {step.icon === 'clock' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            )}
            {step.icon === 'calc' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="4" y="2" width="16" height="20" rx="2"/>
                <path d="M8 6h8M8 10h4M8 14h8M8 18h4"/>
              </svg>
            )}
            {step.icon === 'doc' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <path d="M14 2v6h6M9 15l2 2 4-4"/>
              </svg>
            )}
          </div>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-description">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--space-5xl) 0;
    background: var(--color-white);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .section-label {
    display: inline-block;
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-green);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-size: var(--text-h1);
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .section-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--color-gray-stone);
    max-width: 480px;
    margin: 0 auto;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .step-card {
    position: relative;
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    background: var(--color-white);
    border: 1px solid var(--color-gray-smoke);
    transition: all var(--duration-standard) var(--ease-out);
  }

  .step-card:hover {
    border-color: var(--color-green);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }

  .step-number {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 3rem;
    color: var(--color-gray-smoke);
    line-height: 1;
    transition: color var(--duration-standard) var(--ease-out);
  }

  .step-card:hover .step-number {
    color: rgba(0, 230, 118, 0.15);
  }

  .step-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 230, 118, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-lg);
    color: var(--color-green);
  }

  .step-icon svg {
    width: 24px;
    height: 24px;
  }

  .step-title {
    font-size: var(--text-h3);
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .step-description {
    font-size: var(--text-small);
    color: var(--color-gray-stone);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
