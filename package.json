{
  "name": "control-project",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently --names api,web --kill-others \"pnpm dev:api\" \"sleep 3 && open http://localhost:5173 && pnpm dev:web\"",
    "dev:web": "pnpm --filter @control-project/web dev",
    "dev:landing": "pnpm --filter @control-project/landing dev",
    "dev:api": "pnpm --filter @control-project/api start:dev",
    "build:web": "pnpm --filter @control-project/web build",
    "build:landing": "pnpm --filter @control-project/landing build",
    "build:api": "pnpm --filter @control-project/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
